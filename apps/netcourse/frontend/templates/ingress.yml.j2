apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: {{ app_name }}
  namespace: {{ app_namespace }}
spec:
  secretName: {{ app_tls_secret }}
  commonName: "{{ app_host }}"
  dnsNames:
    - {{ app_host }}
  issuerRef:
    name: {{ cert_issuer }}
    kind: ClusterIssuer
---
apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: {{ app_name }}
  namespace: {{ app_namespace }}
spec:
  entryPoints:
    - websecure
  routes:
    - match: Host(`{{ app_host }}`)
      kind: Rule
      services:
        - name: {{ app_name }}
          port: {{ app_port }}
  tls:
    secretName: {{ app_tls_secret }}
